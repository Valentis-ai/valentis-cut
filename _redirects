# VALENTIS Cut - Netlify Redirects

# Redirect default Netlify subdomain to primary domain
https://valentis-cut.netlify.com/* https://valentis.cut/:splat 301!
https://valentis-cut.netlify.app/* https://valentis.cut/:splat 301!

# WWW to non-WWW
https://www.valentis.cut/* https://valentis.cut/:splat 301!

# HTTP to HTTPS
http://valentis.cut/* https://valentis.cut/:splat 301!
http://www.valentis.cut/* https://valentis.cut/:splat 301!

# Legacy redirects
/old-editor/* / 301
/editor/v1/* / 301
/editor/v2/* / 301

# API redirects
/api/* /.netlify/functions/api/:splat 200

# Admin panel protection
/admin/* /admin/index.html 200

# SPA fallback (باید آخرین خط باشد)
/* /index.html 200

# Custom error pages
/error/404 /404.html 200
/error/500 /500.html 200